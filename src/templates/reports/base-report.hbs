<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>{{title}} - EthicVoice</title>
    <style>
      @page {
        size: A4;
        margin: 0;
      }
      body {
        margin: 0;
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        color: #111;
        background: #ffffff;
        line-height: 1.5;
      }
      .page {
        width: 210mm;
        min-height: 297mm;
        padding: 18mm;
        margin: 0 auto;
        box-sizing: border-box;
      }
      h1 {
        font-size: 22px;
        font-weight: 700;
        color: #111;
        margin: 0 0 4mm 0;
      }
      h2 {
        font-size: 16px;
        font-weight: 700;
        color: #111;
        margin: 8mm 0 3mm 0;
      }
      h3 {
        font-size: 13px;
        font-weight: 600;
        color: #222;
        margin: 5mm 0 2mm 0;
      }
      p {
        font-size: 11px;
        color: #333;
        margin: 0 0 3mm 0;
      }

      /* Official, flat header */
      .header {
        border: 1px solid #e5e7eb;
        padding: 10mm;
        margin-bottom: 10mm;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .header-left {
        display: flex;
        align-items: center;
        gap: 8mm;
      }
      .logo-container {
        width: 22mm;
        height: 22mm;
        border: 1px solid #e5e7eb;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .logo {
        width: 18mm;
        height: 18mm;
        object-fit: contain;
      }
      .header-content h1 {
        color: #111;
        margin: 0 0 2mm 0;
        font-size: 22px;
      }
      .header-subtitle {
        color: #444;
        font-size: 12px;
        margin: 0;
      }
      .header-right {
        text-align: right;
        display: flex;
        flex-direction: column;
        gap: 3mm;
      }
      .org-logo {
        width: 22mm;
        height: 22mm;
        object-fit: contain;
        border: 1px solid #e5e7eb;
        padding: 2mm;
      }
      .org-name {
        font-size: 14px;
        font-weight: 700;
        color: #111;
        margin: 0;
      }
      .report-meta {
        font-size: 10px;
        color: #444;
        margin: 0;
      }

      .section {
        margin-bottom: 10mm;
        page-break-inside: avoid;
      }

      /* Tables: plain, no shadows, no rounding */
      table {
        width: 100%;
        border-collapse: collapse;
        margin: 4mm 0;
      }
      th,
      td {
        font-size: 11px;
        padding: 3mm 2mm;
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
      }
      th {
        background: #f7f7f7;
        font-weight: 700;
        color: #222;
      }
      tr:last-child td {
        border-bottom: 0;
      }

      /* Simple panels and grids */
      .grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6mm;
      }
      .grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6mm;
      }
      .panel {
        border: 1px solid #e5e7eb;
        padding: 5mm;
      }
      .panel-h {
        border-bottom: 1px solid #e5e7eb;
        margin-bottom: 3mm;
      }
      .panel-b {
      }

      .kpi .label {
        font-size: 10px;
        color: #555;
        text-transform: uppercase;
        letter-spacing: 0.02em;
      }
      .kpi .value {
        font-size: 16px;
        font-weight: 700;
        color: #111;
      }
      .kpi .note {
        font-size: 10px;
        color: #666;
      }

      .footer {
        margin-top: 12mm;
        padding-top: 4mm;
        border-top: 1px solid #e5e7eb;
      }
      .footer-content {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: #666;
      }

      @media print {
        .page {
          width: 100%;
          height: 100%;
          padding: 15mm;
        }
        .section {
          page-break-inside: avoid;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="header">
        <div class="header-left">
          <div class="logo-container">
            {{#if ethicVoiceLogo}}
              <img src="{{ethicVoiceLogo}}" alt="EthicVoice" class="logo" />
            {{/if}}
          </div>
          <div class="header-content">
            <h1>{{title}}</h1>
            <p class="header-subtitle">{{subtitle}}</p>
          </div>
        </div>
        <div class="header-right">
          {{#if organizationLogo}}
            <img
              src="{{organizationLogo}}"
              alt="{{organizationName}}"
              class="org-logo"
            />
          {{/if}}
          {{#if organizationName}}
            <div class="org-name">{{organizationName}}</div>
          {{/if}}
          <div class="report-meta">Generado:
            {{formatDate generatedAt "dd/MM/yyyy HH:mm"}}</div>
        </div>
      </div>

      {{{content}}}

      <div class="footer">
        <div class="footer-content">
          <div>EthicVoice Analytics • {{reportId}}</div>
          <div>Confidencial • {{formatDate generatedAt "yyyy"}}</div>
        </div>
      </div>
    </div>
  </body>
</html>