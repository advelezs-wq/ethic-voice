<div class="section" style="display:flex; justify-content:space-between; align-items:flex-start;">
  <div>
    <h1>Invoice</h1>
    <p style="color:#6b7280">Invoice date: {{formatDate invoice.issueDate 'MMM d, yyyy'}}</p>
  </div>
  <div style="text-align:right">
    <p style="color:#6b7280">Invoice # {{invoice.number}}</p>
  </div>
</div>

<div class="section" style="display:flex; justify-content:space-between; gap:24px;">
  <div style="flex:1">
    <div class="section-title" style="margin:0 0 6px 0; border-bottom:0; font-size:12px; text-transform:uppercase; color:#6b7280;">From</div>
    <p style="font-weight:700; color:#111827">{{seller.name}}</p>
    {{#if seller.address}}<p>{{seller.address}}</p>{{/if}}
    {{#if seller.email}}<p>{{seller.email}}</p>{{/if}}
    {{#if seller.phone}}<p>{{seller.phone}}</p>{{/if}}
  </div>
  <div style="flex:1">
    <div class="section-title" style="margin:0 0 6px 0; border-bottom:0; font-size:12px; text-transform:uppercase; color:#6b7280;">Bill to</div>
    <p style="font-weight:700; color:#111827">{{buyer.name}}</p>
    {{#if buyer.address}}<p>{{buyer.address}}</p>{{/if}}
    {{#if buyer.email}}<p>{{buyer.email}}</p>{{/if}}
    {{#if buyer.phone}}<p>{{buyer.phone}}</p>{{/if}}
  </div>
</div>

<div class="section">
  <h2 class="section-title">Description</h2>
  <table>
    <thead>
      <tr>
        <th>DESCRIPTION</th>
        <th style="text-align:right">QTY</th>
        <th style="text-align:right">PRICE</th>
        <th style="text-align:right">Subtotal</th>
      </tr>
    </thead>
    <tbody>
      {{#each invoice.items}}
        <tr>
          <td>{{this.description}}</td>
          <td style="text-align:right">{{this.quantity}}</td>
          <td style="text-align:right">{{formatCurrency this.unitPrice ../invoice.currency}}</td>
          <td style="text-align:right">{{formatCurrency (multiply this.quantity this.unitPrice) ../invoice.currency}}</td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  <div style="margin-top:12px; display:flex; justify-content:flex-end">
    <table class="totals">
      <tr><td>Subtotal</td><td style="text-align:right">{{formatCurrency invoice.subtotal invoice.currency}}</td></tr>
      <tr><td>Tax</td><td style="text-align:right">{{formatCurrency invoice.taxes invoice.currency}}</td></tr>
      <tr class="grand"><td>Grand total</td><td style="text-align:right">{{formatCurrency invoice.total invoice.currency}}</td></tr>
    </table>
  </div>
</div>

<div class="section">
  <h2 class="section-title">Payment</h2>
  <p>Method: {{invoice.paymentMethod}}</p>
  <p>Issued: {{formatDate invoice.issueDate 'MMM d, yyyy HH:mm'}}</p>
  {{#if invoice.externalReference}}<p>External reference: {{invoice.externalReference}}</p>{{/if}}
  {{#if invoice.providerId}}<p>Provider ID: {{invoice.providerId}}</p>{{/if}}
</div>

<div class="section">
  <p style="font-size:12px; color:#6b7280">This document is a visual representation of the payment receipt generated by EthicVoice. For DIAN e-invoicing, numbered electronic invoices are issued when applicable. Keep this document for your records.</p>
</div>
