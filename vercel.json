{
  "framework": "nextjs",
  "buildCommand": "bun run build",
  "installCommand": "bun install",
  "crons": [
    {
      "path": "/api/admin/daily-runner",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/digest/weekly",
      "schedule": "0 6 * * 1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
