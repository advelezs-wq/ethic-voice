<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Invoice - EthicVoice</title>
    <style>
      @page {
        size: A4;
        margin: 0;
      }

      body {
        margin: 0;
        font-family:
          "Inter",
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
        color: #111827; /* neutral, no brand colors */
        background: #ffffff;
        line-height: 1.6;
        font-size: 14px;
      }

      .page {
        width: 210mm;
        min-height: 297mm;
        padding: 20mm;
        margin: 0 auto;
        box-sizing: border-box;
      }

      h1 {
        font-size: 28px;
        font-weight: 800;
        margin: 0 0 6px 0;
      }
      h2 {
        font-size: 20px;
        font-weight: 700;
        margin: 24px 0 12px 0;
      }
      p {
        margin: 0 0 6px 0;
        color: #374151;
      }

      .section {
        margin-bottom: 28px;
        page-break-inside: avoid;
      }
      .section-title {
        font-size: 18px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 10px 0;
        padding-bottom: 6px;
        border-bottom: 1px solid #e5e7eb;
      }

      /* Tables: neutral, thin borders */
      table {
        width: 100%;
        border-collapse: collapse;
      }
      th,
      td {
        padding: 8px 0;
        border-bottom: 1px solid #e5e7eb;
      }
      th {
        text-align: left;
        font-size: 11px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: #6b7280;
        font-weight: 700;
      }

      .totals {
        width: 320px;
        font-size: 14px;
      }
      .totals td {
        border: 0;
        padding: 6px 0;
      }
      .totals .grand td {
        font-weight: 800;
      }

      /* Header logo strip */
      .header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
      }
      .brand {
        height: 32px;
      }

      /* Footer */
      .footer {
        margin-top: 40px;
        padding-top: 12px;
        border-top: 1px solid #e5e7eb;
        font-size: 12px;
        color: #6b7280;
      }

      @media print {
        .page {
          width: 100%;
          height: 100%;
          padding: 15mm;
        }
        .section {
          page-break-inside: avoid;
        }
      }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="header">
        {{#if ethicVoiceLogo}}
          <img class="brand" src="{{ethicVoiceLogo}}" alt="EthicVoice" />
        {{/if}}
      </div>
      {{{content}}}
      <div class="footer">Documento generado por EthicVoice</div>
    </div>
  </body>
</html>