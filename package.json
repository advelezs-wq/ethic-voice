{
  "name": "ethic-voice",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "postinstall": "CHECKPOINT_DISABLE=1 PRISMA_HIDE_UPDATE_MESSAGE=1 PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma generate --no-hints",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "dev:demo": "NEXT_PUBLIC_DEMO_MODE=true next dev --webpack",
    "dev:real": "NEXT_PUBLIC_DEMO_MODE=false next dev --webpack",
    "db:generate": "CHECKPOINT_DISABLE=1 PRISMA_HIDE_UPDATE_MESSAGE=1 PRISMA_GENERATE_SKIP_AUTOINSTALL=1 prisma generate --no-hints",
    "build": "next build",
    "build:with-prisma": "bun run db:generate && next build",
    "start": "next start",
    "lint": "next lint",
    "workers": "tsx workers/index.ts",
    "workers:dev": "NODE_ENV=development tsx workers/index.ts",
    "workers:prod": "NODE_ENV=production tsx workers/index.ts",
    "queue:status": "curl -s http://localhost:3000/api/admin/process-queue | jq",
    "queue:process": "curl -s -X POST http://localhost:3000/api/admin/process-queue | jq",
    "test:pricing": "bunx tsx scripts/test-pricing-system.ts",
    "setup:pricing": "bunx --bun prisma migrate deploy && bun run db:generate && bun run test:pricing",
    "validate:security": "curl -X POST http://localhost:3000/api/admin/security/validate-plans -H 'Authorization: Bearer ${ADMIN_API_SECRET}'",
    "pricing:dev": "bun run dev",
    "pricing:build": "bun run build && bun run test:pricing",
    "rebill:test": "echo 'Testing Rebill integration...' && curl -X POST http://localhost:3000/api/webhooks/rebill -H 'Content-Type: application/json' -d '{\"test\": true}'",
    "create-rebill-plans": "bunx tsx scripts/create-rebill-plans.ts",
    "test:rebill": "bunx tsx scripts/test-rebill-integration.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^0.0.66",
    "@auth/prisma-adapter": "^2.7.2",
    "@clerk/localizations": "^3.4.1",
    "@clerk/nextjs": "^6.28.0",
    "@clerk/themes": "^2.4.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@frigade/react": "^2.10.1",
    "@hcaptcha/react-hcaptcha": "^1.12.0",
    "@heroui/react": "^2.2.9",
    "@hookform/resolvers": "^3.9.0",
    "@internationalized/date": "^3.8.2",
    "@langchain/core": "^0.3.15",
    "@langchain/openai": "^0.3.9",
    "@prisma/client": "^5.21.1",
    "@sparticuz/chromium": "^138.0.2",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@upstash/redis": "^1.34.0",
    "ai": "^3.4.32",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.15.0",
    "cloudinary": "^2.5.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.7",
    "googleapis": "^154.1.0",
    "handlebars": "^4.7.8",
    "hls.js": "^1.6.16",
    "ioredis": "^5.4.1",
    "limiter": "^2.1.0",
    "next": "^16.1.6",
    "nodemailer": "^6.9.15",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^24.16.2",
    "pusher": "^5.2.0",
    "pusher-js": "^8.4.0-rc2",
    "react": "^19.0.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "react-floating-whatsapp": "^5.0.8",
    "react-hook-form": "^7.53.0",
    "recharts": "^3.1.0",
    "resend": "^4.7.0",
    "sanitize-html": "^2.17.3",
    "sonner": "^2.0.7",
    "svix": "^1.33.0",
    "uuid": "^10.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@iconify/json": "^2.2.346",
    "@iconify/tailwind": "^1.2.0",
    "@types/node": "^24.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "concurrently": "^9.2.0",
    "critters": "^0.0.25",
    "eslint": "^8",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8",
    "prisma": "^5.21.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.3",
    "typescript": "^5"
  }
}
